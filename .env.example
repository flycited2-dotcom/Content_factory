# Скопировать в .env (gitignored) и заполнить. Реальные значения брать server-side, НЕ коммитить.

# БД oasis (источник контента) — креды как в /opt/avito-bridge/.env
DB_HOST=172.30.0.6
DB_PORT=5432
DB_NAME=oasis_db
DB_USER=oasis_user
DB_PASSWORD=

# JAC (без API): путь к JSON остатков
JAC_STOCK_JSON=

# Фотоагент (очередь на VPS, рядом с ritualb2b)
FOTOGEN_API_URL=http://127.0.0.1:8765
FOTOGEN_API_TOKEN=
FOTOGEN_CHAT_ID=1264067528
FOTOGEN_QUEUE_DB=/root/ritualb2b/queue.db
FOTOGEN_OUTPUT_DIR=/root/ritualb2b/output
FOTOGEN_MODE=mcp
FOTOGEN_MODES_JSON=config/card_modes.json
FOTOGEN_PER_RUN=10
FOTOGEN_MAX_PENDING=12
FOTOGEN_MAX_TOTAL=100000

# Telegram (бот — админ канала)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=@your_channel
TELEGRAM_TEST_CHANNEL_ID=
